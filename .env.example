# SSH target for the GB10 / DGX Spark box.
TARGET_HOST=gb10.example.ts.net
TARGET_USER=dell
TARGET_PORT=22

# Where the full playbook repo will be synced on the target host.
REMOTE_PLAYBOOK_DIR=/home/dell/src/github.com/spencerbull/gb10-gemma4-playbook

# Deployment settings.
MODEL_ID=bg-digitalservices/Gemma-4-26B-A4B-it-NVFP4A16
RECIPE=gemma4-26b-a4b-nvfp4a16
VLLM_PORT=8000

# Optional server-wide Gemma4 thinking default.
# Allowed values: auto, on, off
# - auto: leave the model default untouched
# - on:   set --default-chat-template-kwargs '{"enable_thinking": true}'
# - off:  set --default-chat-template-kwargs '{"enable_thinking": false}'
GEMMA4_THINKING_DEFAULT=auto

# Benchmark defaults.
BENCHMARK_RUNS=2
BENCHMARK_MAX_TOKENS=256
BENCHMARK_LARGE_TARGET_TOKENS=240000
